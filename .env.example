# Neon PostgreSQL — same DB as api-simulator
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Tenderly virtual fork RPC — Admin (private) RPC URL
# Get from: https://dashboard.tenderly.co → your VNet → Admin RPC
RPC_URL=https://virtual.rpc.tenderly.co/your-org/project/private/your-vnet/your-id

# Deployed FactoryMatch contract address on the Tenderly fork
FACTORY_ADDRESS=0x602473fc59ff5eefbe5d6c86d3af5c64ac7987bc

# Owner wallet private key (must be the owner of FactoryMatch)
OWNER_PRIVATE_KEY=0xyour-private-key-here

# Admin API base URL (api-simulator)
API_URL=http://localhost:8080
